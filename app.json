{
  "expo": {
    "name": "Momora",
    "slug": "momora",
    "version": "1.1.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "momora",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.memora.app",
      "associatedDomains": [
        "applinks:usemomora.com"
      ],
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#FAFAFD",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "package": "com.memora.app",
      "googleServicesFile": "./google-services.json",
      "predictiveBackGestureEnabled": false,
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "https",
              "host": "usemomora.com",
              "pathPrefix": "/invite"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "resizeMode": "contain",
          "backgroundColor": "#FAFAFD"
        }
      ],
      "expo-image",
      [
        "expo-image-picker",
        {
          "photosPermission": "Momora uses your photo library to add family profile photos for character portraits.",
          "cameraPermission": "Momora uses your camera to take family profile photos for character portraits."
        }
      ],
      [
        "expo-audio",
        {
          "microphonePermission": "Momora uses your microphone to record voice memories, which are transcribed into journal entries."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/images/notification-icon.png",
          "color": "#D63E78"
        }
      ],
      "@react-native-community/datetimepicker",
      "expo-video",
      "expo-asset"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "6e6727aa-fe88-482c-ad1b-6e108b235f54"
      }
    }
  }
}
