{
  "expo": {
    "name": "Momora",
    "slug": "momora",
    "version": "1.1.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "momora",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.memora.app",
      "associatedDomains": [
        "applinks:usemomora.com"
      ],
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "allowBackup": false,
      "blockedPermissions": [
        "android.permission.FOREGROUND_SERVICE",
        "android.permission.FOREGROUND_SERVICE_MEDIA_PLAYBACK"
      ],
      "adaptiveIcon": {
        "backgroundColor": "#D63E78",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "package": "com.memora.app",
      "googleServicesFile": "./google-services.json",
      "predictiveBackGestureEnabled": false,
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "https",
              "host": "usemomora.com",
              "pathPrefix": "/invite"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "resizeMode": "contain",
          "backgroundColor": "#D63E78"
        }
      ],
      "expo-image",
      [
        "expo-image-picker",
        {
          "photosPermission": "Momora uses your photo library to add photos and videos to family memories and profile photos for family members.",
          "cameraPermission": "Momora uses your camera to take photos for family memories and family member profiles."
        }
      ],
      [
        "expo-audio",
        {
          "microphonePermission": "Momora uses your microphone to record voice memories, which are transcribed into journal entries.",
          "enableBackgroundPlayback": false
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/images/notification-icon.png",
          "color": "#D63E78"
        }
      ],
      "@react-native-community/datetimepicker",
      "expo-video",
      "expo-asset",
      [
        "expo-sharing",
        {
          "ios": {
            "enabled": true,
            "appGroupId": "group.com.memora.app.shared",
            "activationRule": {
              "supportsAttachmentsWithMaxCount": 10,
              "supportsImageWithMaxCount": 10,
              "supportsMovieWithMaxCount": 10
            }
          },
          "android": {
            "enabled": true,
            "singleShareMimeTypes": [
              "image/*",
              "video/*"
            ],
            "multipleShareMimeTypes": [
              "image/*",
              "video/*"
            ]
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "6e6727aa-fe88-482c-ad1b-6e108b235f54"
      }
    }
  }
}
