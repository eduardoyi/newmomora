# Momora — environment template
# Copy to .env.local and fill in values. NEVER commit .env.local or real keys.

# --- Client (Expo) — safe to expose in app bundle ---
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# --- NOT in client .env ---
# OPENAI_API_KEY, R2_*, SUPABASE_SERVICE_ROLE_KEY → supabase/.env.local only
# See supabase/.env.example and docs/COST_OPTIMIZATION.md
