# Momora — environment template
# Copy to .env.local and fill in values. NEVER commit .env.local or real keys.

# --- Client (Expo) — safe to expose in app bundle ---
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# --- NOT in client .env ---
# OPENAI_API_KEY, R2_*, SUPABASE_SERVICE_ROLE_KEY → server-only configuration.
# MEMORY_ILLUSTRATION_BACKEND=legacy|cloudflare belongs in Supabase function
# secrets/config, never in EXPO_PUBLIC_* or this client file. Cloudflare
# Workflow secrets (OPENAI_API_KEY, bridge HMAC, dispatch secret) belong only
# in the Worker secret store. See docs/cloudflare-illustration-workflows.md.
