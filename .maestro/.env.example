# Maestro e2e credentials (gitignored)
# Copy to .env.local and fill with a real Supabase test account
TEST_EMAIL=
TEST_PASSWORD=

# Run with:
# maestro test -e TEST_EMAIL=you@example.com -e TEST_PASSWORD=secret .maestro/flows/

# Family profile upload flows (dev client only):
# CI / reliable upload path (bundled E2E fixture photo):
# maestro test -e TEST_EMAIL=... -e TEST_PASSWORD=... .maestro/flows/onboarding/add-family-member-with-fixture.yaml
#
# Real system photo picker (optional / pre-release):
# maestro test -e TEST_EMAIL=... -e TEST_PASSWORD=... .maestro/flows/onboarding/add-family-member-with-picker.yaml
