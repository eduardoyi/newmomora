# Supabase Edge Functions — add to supabase/.env.local (gitignored)
# Production: supabase secrets set KEY=value

OPENAI_API_KEY=
SUPABASE_SERVICE_ROLE_KEY=
CRON_SECRET=

# Cloudflare R2 (S3-compatible) — images only; NOT in client
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_ENDPOINT=https://YOUR_ACCOUNT_ID.r2.cloudflarestorage.com
R2_BUCKET=momora-prod
R2_PUBLIC_ASSETS_BASE_URL=https://assets.yourdomain.com
