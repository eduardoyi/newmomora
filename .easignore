# EAS Build upload filter. When this file exists, EAS uses it INSTEAD of
# .gitignore — keep the two in sync, with one deliberate difference:
# google-services.json stays out of git (see .gitignore) but MUST be uploaded
# to EAS so Android builds can configure FCM push. Never remove the keystore
# or credentials.json exclusions below.

# Dependencies
node_modules/

# --- Secrets & environment (NEVER COMMIT) ---
.env
.env.*
!.env.example
*.env.local
supabase/.env
supabase/.env.*
!supabase/.env.example

# API keys and credentials
**/secrets/
*.pem
*.key
*.p8
*.p12
*.jks
*.keystore
*.mobileprovision
*.cer
*.crt
credentials.json
service-account*.json

# Firebase / Google — google-services.json is intentionally NOT listed here
# (uploaded to EAS for FCM); the iOS plist remains excluded.
GoogleService-Info.plist

# Expo
.expo/
dist/
web-build/
expo-env.d.ts

# Native (generated locally; may contain signing config)
ios/
android/

# OS
.DS_Store
Thumbs.db
*.swp
*.swo

# IDE
.idea/
.vscode/settings.json.local

# Supabase local
supabase/.temp/
supabase/.branches/

# TypeScript
*.tsbuildinfo

# Testing
coverage/
.env.test.local
.maestro/report/
.maestro/.env.local

# EAS
.eas/
eas-build-*.json

# Logs (may accidentally contain tokens)
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Misc
.turbo/
.cache/
*.orig
supabase/functions/deno.lock
supabase/scripts/eval-output/
