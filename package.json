{
  "name": "momora",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "start": "expo start --dev-client",
    "android": "expo start --android --dev-client",
    "ios": "expo start --ios --dev-client",
    "web": "expo start --web",
    "typecheck": "tsc --noEmit",
    "lint": "expo lint",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:edge": "deno test --allow-env --allow-net --allow-ffi --allow-read=supabase/functions,supabase/scripts,src/utils --node-modules-dir=none supabase/functions/ supabase/scripts/",
    "eval:portrait": "npx --yes deno run --allow-all --env-file=supabase/.env.local --env-file=.env.local supabase/scripts/eval-portrait.ts",
    "eval:illustration": "npx --yes deno run --allow-all --env-file=supabase/.env.local --env-file=.env.local supabase/scripts/eval-illustration.ts",
    "regenerate:illustrations": "npx --yes deno run --allow-all --env-file=supabase/.env.local --env-file=.env.local supabase/scripts/regenerate-illustrations.ts",
    "backfill:previews": "npx --yes deno run --allow-all --node-modules-dir=none --env-file=supabase/.env.local --env-file=.env.local supabase/scripts/backfill-media-previews.ts",
    "backfill:video-posters": "npx --yes deno run --allow-all --node-modules-dir=none --env-file=supabase/.env.local --env-file=.env.local supabase/scripts/backfill-video-posters.ts",
    "test:e2e:family-fixture": "maestro test .maestro/flows/onboarding/add-family-member-with-fixture.yaml",
    "test:e2e:family-picker": "maestro test .maestro/flows/onboarding/add-family-member-with-picker.yaml"
  },
  "dependencies": {
    "@expo-google-fonts/caveat": "^0.4.2",
    "@expo-google-fonts/newsreader": "^0.4.1",
    "@expo-google-fonts/plus-jakarta-sans": "^0.4.2",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-community/datetimepicker": "9.1.0",
    "@supabase/supabase-js": "^2.107.0",
    "@tanstack/react-query": "^5.90.11",
    "@types/ws": "^8.18.1",
    "expo": "~56.0.16",
    "expo-asset": "~56.0.19",
    "expo-audio": "~56.0.12",
    "expo-auth-session": "~56.0.15",
    "expo-constants": "~56.0.15",
    "expo-dev-client": "~56.0.23",
    "expo-file-system": "~56.0.7",
    "expo-font": "~56.0.5",
    "expo-haptics": "~56.0.3",
    "expo-image": "~56.0.11",
    "expo-image-manipulator": "~56.0.22",
    "expo-image-picker": "~56.0.21",
    "expo-linear-gradient": "~56.0.4",
    "expo-linking": "~56.0.15",
    "expo-notifications": "~56.0.21",
    "expo-router": "~56.2.15",
    "expo-sharing": "~56.0.22",
    "expo-splash-screen": "~56.0.13",
    "expo-status-bar": "~56.0.4",
    "expo-symbols": "~56.0.6",
    "expo-updates": "~56.0.22",
    "expo-video": "~56.1.4",
    "expo-video-thumbnails": "^56.0.3",
    "expo-web-browser": "~56.0.5",
    "lucide-react-native": "^1.24.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-native": "0.85.3",
    "react-native-compressor": "^1.16.0",
    "react-native-gesture-handler": "~2.31.1",
    "react-native-keyboard-controller": "1.21.6",
    "react-native-reanimated": "4.3.1",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "4.25.2",
    "react-native-svg": "15.15.4",
    "react-native-web": "~0.21.0",
    "react-native-worklets": "0.8.3",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@testing-library/jest-native": "^5.4.3",
    "@testing-library/react-native": "^13.3.3",
    "@types/jest": "^29.5.14",
    "@types/react": "~19.2.2",
    "eslint": "^9.0.0",
    "eslint-config-expo": "~56.0.4",
    "jest": "^29.7.0",
    "jest-expo": "~56.0.5",
    "react-test-renderer": "19.2.3",
    "typescript": "~6.0.3"
  }
}
